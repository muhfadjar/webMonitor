# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=webmonitor
POSTGRES_PASSWORD=changeme
POSTGRES_DB=webmonitor

# Full connection string used by Prisma (auto-built from above in Docker)
DATABASE_URL=postgresql://webmonitor:changeme@localhost:5432/webmonitor

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─────────────────────────────────────────────
# Seed / default admin user
# Created automatically on first `docker compose up`
# Change password after first login!
# ─────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@webmonitor.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin

# ─────────────────────────────────────────────
# Next.js / Auth
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-32-char-random-string
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Worker tuning (all optional — defaults shown)
# ─────────────────────────────────────────────
PAGE_CHECK_CONCURRENCY=20
SITE_DISCOVERY_CONCURRENCY=5
SSL_CHECK_CONCURRENCY=10
REQUEST_TIMEOUT_MS=10000
SITEMAP_TIMEOUT_MS=15000
MAX_SITEMAPS=200
MAX_PAGES=50000
USER_AGENT=WebMonitor/1.0

# ─────────────────────────────────────────────
# pgAdmin (only used with --profile debug)
# ─────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ─────────────────────────────────────────────
# Alerts (Phase 6)
# ─────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=
# SMTP_FROM=WebMonitor <alerts@example.com>
